                    <run fontalignment='1' fontcolor='#f5f5f5'> &lt;Full Name&gt;</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#03c4a1'>___________________________________________________________________</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>Full </run>
                    <run fontalignment='1' fontcolor='#03c4a1'>Step By Step guide</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'> to build this Dashboard </run>
                    <run auto-url='true' fontalignment='1' fontcolor='#f5f5f5' hyperlink='tabdoc:load-url url=&amp;quot;https://youtu.be/UcGF09Awm4Y&amp;quot;'>https://youtu.be/UcGF09Awm4Y</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#03c4a1'>Subscribe</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'> for more content like this </run>
                    <run auto-url='true' fontalignment='1' fontcolor='#f5f5f5' hyperlink='tabdoc:load-url url=&amp;quot;https://www.youtube.com/@DataWithBaraa&amp;quot;'>https://www.youtube.com/@DataWithBaraa</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>Connect to </run>
                    <run fontalignment='1' fontcolor='#03c4a1'>LinkedIn</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>Æ </run>
                    <run auto-url='true' fontalignment='1' fontcolor='#f5f5f5' hyperlink='tabdoc:load-url url=&amp;quot;https://www.linkedin.com/in/baraa-khatib-salkini-845b1b55/&amp;quot;'>https://www.linkedin.com/in/baraa-khatib-salkini-845b1b55/</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#03c4a1'>___________________________________________________________________</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run bold='true' fontalignment='1' fontcolor='#03c4a1'>Hover</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'> over the chart to see more information.</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>Click on the chart to </run>
                    <run bold='true' fontalignment='1' fontcolor='#03c4a1'>filter</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'> the entire dashboard.</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>Click the switch icon on the top right corner to open the</run>
                    <run bold='true' fontalignment='1' fontcolor='#03c4a1'> filter menu</run>
                    <run fontalignment='1' fontcolor='#f5f5f5'>.</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#03c4a1'>___________________________________________________________________</run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
