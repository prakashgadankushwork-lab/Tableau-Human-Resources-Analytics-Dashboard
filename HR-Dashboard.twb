    <worksheet name='test'>
      <repository-location id='test' path='/workbooks/HRDashboard_17785960443740' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='HumanResources' name='federated.1uy6vyf0tya8w3119f4041qdymfc' />
          </datasources>
          <datasource-dependencies datasource='federated.1uy6vyf0tya8w3119f4041qdymfc'>
            <column datatype='date' name='[Birthdate]' role='dimension' type='ordinal' />
            <column caption='Status' datatype='string' name='[Calculation_2981664453132697602]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Termdate]) THEN &apos;Hired&apos;&#13;&#10;ELSE &apos;Terminated&apos;&#13;&#10;END' />
            </column>
            <column caption='Location' datatype='string' name='[Calculation_3363625995846344715]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &apos;New York&apos; THEN &apos;HQ&apos;&#13;&#10;    ELSE &apos;Branch&apos;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='integer' name='[Calculation_3363625995860541454]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [Birthdate], TODAY())' />
            </column>
            <column caption='Age Groups' datatype='string' name='[Calculation_3363625995862552598]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_3363625995860541454] &lt; 25 THEN &apos;&gt;25&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=25 AND [Calculation_3363625995860541454] &lt; 35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=35 AND [Calculation_3363625995860541454] &lt; 45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=45 AND [Calculation_3363625995860541454] &lt; 55 THEN &apos;45-54&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=55 THEN &apos;55+&apos;&#13;&#10;END' />
