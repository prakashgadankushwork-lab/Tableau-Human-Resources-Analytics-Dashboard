        </calculation>
      </column>
      <column caption='Status' datatype='string' name='[Calculation_2981664453132697602]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Termdate]) THEN &apos;Hired&apos;&#13;&#10;ELSE &apos;Terminated&apos;&#13;&#10;END' />
      </column>
      <column caption='Highlight Max' datatype='boolean' name='[Calculation_2981664453136855046]' role='measure' type='nominal'>
        <calculation class='tableau' formula='WINDOW_MAX([Calculation_3363625995831468034]) = [Calculation_3363625995831468034]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Hired' datatype='integer' name='[Calculation_3363625995831468034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Employee_ID])' />
      </column>
      <column caption='Total Terminated' datatype='integer' name='[Calculation_3363625995832086533]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF NOT ISNULL([Termdate]) THEN [Employee_ID] END)' />
      </column>
      <column caption='Total Active' datatype='integer' name='[Calculation_3363625995833364486]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF ISNULL([Termdate]) THEN [Employee_ID] END)' />
      </column>
      <column caption='Location' datatype='string' name='[Calculation_3363625995846344715]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &apos;New York&apos; THEN &apos;HQ&apos;&#13;&#10;    ELSE &apos;Branch&apos;&#13;&#10;END' />
      </column>
      <column caption='Age' datatype='integer' name='[Calculation_3363625995860541454]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [Birthdate], TODAY())' />
      </column>
      <column caption='Age Groups' datatype='string' name='[Calculation_3363625995862552598]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_3363625995860541454] &lt; 25 THEN &apos;&gt;25&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=25 AND [Calculation_3363625995860541454] &lt; 35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=35 AND [Calculation_3363625995860541454] &lt; 45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=45 AND [Calculation_3363625995860541454] &lt; 55 THEN &apos;45-54&apos;&#13;&#10;ELSEIF [Calculation_3363625995860541454] &gt;=55 THEN &apos;55+&apos;&#13;&#10;END' />
      </column>
      <column caption='Full Name' datatype='string' name='[Calculation_990228993555632131]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[First Name] + &apos; &apos; + [Last Name]' />
      </column>
      <column caption='Length of Hire' datatype='integer' name='[Calculation_990228993560891399]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL ([Termdate]) &#13;&#10;THEN DATEDIFF(&apos;year&apos;, [Hiredate], TODAY())&#13;&#10;ELSE DATEDIFF(&apos;year&apos;, [Hiredate], [Termdate])&#13;&#10;END' />
      </column>
